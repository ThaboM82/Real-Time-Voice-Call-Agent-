# --- Project specific ignores ---

# Environment & secrets
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env

# Runtime JSON caches
transcripts.json
tags.json

# Logs
logs/
*.log

# Local databases
*.db
backend/test.db

# Virtual environments (if any)
venv/

# --- Node.js / Next.js standard ignores ---

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build outputs
.next/
out/
dist/
build/

# Debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage reports
coverage/

# TypeScript
*.tsbuildinfo

# Misc
.DS_Store
Thumbs.db

# --- Editor / IDE ignores ---
.vscode/
.idea/

# --- Swap / temp files ---
*.swp
